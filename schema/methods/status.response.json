{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StatusResponse",
  "type": "object",
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": { "type": "integer" },
    "result": {
      "type": "object",
      "required": ["grabbed_window", "last_snapshot_id"],
      "properties": {
        "grabbed_window": { "type": ["string", "null"] },
        "last_snapshot_id": { "type": ["string", "null"] },
        "daemon_pid": { "type": ["integer", "null"] },
        "daemon_uptime_ms": { "type": ["integer", "null"] }
      }
    }
  }
}
