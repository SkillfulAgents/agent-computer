{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SnapshotResponse",
  "type": "object",
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": { "type": "integer" },
    "result": {
      "type": "object",
      "required": ["snapshot_id", "window", "elements", "fallback"],
      "properties": {
        "snapshot_id": { "type": "string" },
        "window": { "$ref": "../types/window-info.json" },
        "elements": {
          "type": "array",
          "items": { "$ref": "../types/element.json" }
        },
        "fallback": { "type": ["string", "null"], "enum": ["ocr", null] }
      }
    }
  }
}
