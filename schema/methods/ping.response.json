{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PingResponse",
  "type": "object",
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": { "type": "integer" },
    "result": {
      "type": "object",
      "required": ["pong"],
      "properties": {
        "pong": { "const": true }
      }
    }
  }
}
