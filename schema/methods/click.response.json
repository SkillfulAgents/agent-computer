{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClickResponse",
  "type": "object",
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": { "type": "integer" },
    "result": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "const": true },
        "ref": { "type": "string" },
        "bounds": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        }
      }
    }
  }
}
