{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedRole",
  "description": "Platform-normalized UI element role",
  "type": "string",
  "enum": [
    "button", "textfield", "textarea", "link", "checkbox", "radio",
