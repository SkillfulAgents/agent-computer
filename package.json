{
  "name": "@skillful-agents/ac",
  "version": "0.1.0",
  "description": "Agent Computer — native macOS desktop automation CLI for AI agents",
  "type": "module",
  "bin": {
    "ac": "./dist/bin/ac.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "bin/ac-core",
    "scripts/",
    "schema/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:swift": "cd native/macos && swift build -c release",
    "build:all": "npm run build && npm run build:swift",
    "postinstall": "node scripts/postinstall.js || true",
    "prepublishOnly": "npm run build",
    "test": "vitest run test/contract/ test/unit/",
    "test:contract": "vitest run test/contract/",
    "test:unit": "vitest run test/unit/",
    "test:integration": "vitest run test/integration/",
    "test:functional": "vitest run test/functional/",
    "test:e2e": "vitest run test/e2e/ --timeout 120000",
    "test:all": "vitest run",
    "test:watch": "vitest watch test/unit/ test/contract/",
    "typecheck": "tsc --noEmit",
    "ac": "tsx bin/ac.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ajv": "^8.17.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20",
    "os": "darwin"
  },
  "os": ["darwin"],
  "cpu": ["arm64", "x64"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/datawizz/ac"
  }
}
